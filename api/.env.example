MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_here

# Cloudinary (photo storage — required for /upload and /upload-by-link)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Set to "production" when deployed behind HTTPS on a different domain than
# the client (enables SameSite=None; Secure auth cookies). Leave unset for
# local development over http://localhost.
NODE_ENV=
